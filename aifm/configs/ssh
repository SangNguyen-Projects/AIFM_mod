NODE_IPS=("128.110.218.62:sangbob" "128.110.218.54:sangbob" "128.110.218.53:sangbob")

function ssh_execute {
    local index=$1
    local cmd=$2
    local node=${NODE_IPS[$index]}
    local ip=${node%:*}
    local user=${node#*:}
    ssh $user@$ip "$cmd"
}

function ssh_execute_tty {
    local index=$1
    local cmd=$2
    local node=${NODE_IPS[$index]}
    local ip=${node%:*}
    local user=${node#*:}
    ssh $user@$ip -t "$cmd"
}